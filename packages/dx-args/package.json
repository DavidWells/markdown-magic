{
  "name": "@davidwells/dx-args",
  "version": "0.2.1",
  "description": "A forgiving argv parser for CLIs that accepts loose key/value syntax, globs, and typo-tolerant long flags.",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "bin": {
    "dx-args": "src/index.js"
  },
  "files": [
    "src",
    "types",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "argv",
    "args",
    "cli",
    "parser",
    "forgiving",
    "glob"
  ],
  "author": "David Wells",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavidWells/markdown-magic",
    "directory": "packages/dx-args"
  },
  "scripts": {
    "test": "uvu test '.test.([mc]js|[jt]sx?)$'",
    "types": "tsc --emitDeclarationOnly --outDir types",
    "build": "pnpm run types",
    "clean": "rimraf types coverage .nyc_output",
    "postpublish": "git push origin && git push origin --tags",
    "release:patch": "pnpm version patch --git-tag-version && pnpm publish",
    "release:minor": "pnpm version minor --git-tag-version && pnpm publish",
    "release:major": "pnpm version major --git-tag-version && pnpm publish"
  },
  "dependencies": {
    "is-glob": "^4.0.3",
    "is-valid-path": "^0.1.1",
    "mri": "^1.2.0",
    "oparser": "^3.1.1"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "uvu": "^0.5.6"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
