{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationDir": "./types",
    "allowJs": true,
    "checkJs": false,
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2020"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "types", "**/*.test.js", "**/*.bench.js"]
}
